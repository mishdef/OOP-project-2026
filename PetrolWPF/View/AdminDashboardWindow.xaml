<Window x:Class="Gsstwpfmock.AdminDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Gsstwpfmock"
        mc:Ignorable="d"
        Title="Admin Dashboard" Height="450" Width="800"
        Background="#F4F4F4" WindowStartupLocation="CenterOwner"
        MinHeight="550"
        MinWidth="900"
        Icon="/Accets/logo.jpg">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" MinWidth="150"/>
            <ColumnDefinition Width="3*" MinWidth="400"/>
        </Grid.ColumnDefinitions>


        <!--SIDEBAR-->
        
        <Border Grid.Column="0" 
                Margin="0,0,10,0" 
                Background="#F9F9F9" 
                CornerRadius="5"/>
        <StackPanel Grid.Column="0"
                        Margin="0,0,10,0">
            <StackPanel.Resources>
                <Style TargetType="{x:Type Button}">
                    <Setter Property="Margin" Value="0,0,0,10"/>
                    <Setter Property="Height" Value="35"/>
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    <Setter Property="Padding" Value="10,0,0,0"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Background" Value="#FEFEFE"/>

                </Style>
            </StackPanel.Resources>
            <Label Content="Dashboard" 
                   Margin="4,5,0,10" 
                   FontWeight="Bold"
                   FontSize="16"/>
            <Button x:Name="StatisticsBtn" 
                    Content="Statistics" 
                    Click="StatisticsButton_Click"
                    Background="#EAEAEA"/>
            <Button x:Name="UsersBtn" 
                    Content="Users" 
                    Click="UsersButton_Click"/>
            <Button x:Name="StockBtn" 
                    Content="Stock" 
                    Click="StockButton_Click"/>
            <Button x:Name="EquipmentBtn"
                    Content="Equipment"
                    Click="EquipmentBtn_Click"/>
            <Button x:Name="HistoryBtn" 
                    Content="Transaction History" 
                    Click="HistoryButton_Click"/>
            <Button x:Name="ReportsBtn" 
                    Content="Reports" 
                    Click="ReportsButton_Click"/>
            <Button x:Name="SettingsBtn" 
                    Content="Settings" 
                    Click="SettingsButton_Click"/>
            
                
        </StackPanel>

        <GridSplitter Grid.Column="0"
                  Width="5"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Stretch"
                  Background="Transparent"
                  ShowsPreview="True"
                  Cursor="SizeWE"/>

        <Grid x:Name="HistoryGrid" Grid.Row="1" Grid.Column="1" Visibility="Hidden">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <Label Grid.Row="0" FontWeight="Bold">TRANSACTION HISTORY</Label>

            <DataGrid Grid.Row="1" ItemsSource="{Binding AllOrders}" 
              SelectedItem="{Binding SelectedOrder}"
              AutoGenerateColumns="False" IsReadOnly="True" Margin="0,5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Date/Time" Binding="{Binding Date, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="150"/>
                    <DataGridTextColumn Header="Cashier" Binding="{Binding User.Username}" Width="120"/>
                    <DataGridTextColumn Header="Total Amount" Binding="{Binding Total, StringFormat={}{0:F2} $}" Width="100"/>
                    <DataGridTextColumn Header="Bonuses Used" Binding="{Binding BonusSpent, StringFormat={}{0:F2}}" Width="100"/>
                    <DataGridTextColumn Header="Bonus Card" Binding="{Binding BonusCardId}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" Background="#DCDCDC"/>

            <GroupBox Grid.Row="3" Header="Receipt Details" Margin="0,10,0,0">
                <DataGrid ItemsSource="{Binding SelectedOrder.Items}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Item/Fuel" Binding="{Binding Product.Name}" Width="*"/>

                        <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="80"/>

                        <DataGridTextColumn Header="Price" Binding="{Binding Product.Price, StringFormat={}{0:F2} $}" Width="80"/>

                        <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat={}{0:F2} $}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>

        <!--Statistics Grid-->

        <Grid x:Name="StatisticsGrid" Grid.Row="1" Grid.Column="1" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0" FontWeight="Bold">STATISTICS</Label>

            <TabControl Grid.Row="1" Background="#FEFEFE">
                <TabItem Header="Fuel &amp; Pumps">
                    <StackPanel Margin="10">
                        <TextBlock Text="Fuel Income Stats:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding TotalFuelIncome, StringFormat='Total Fuel Income: {0:F2}$'}" />
                        <TextBlock Text="{Binding AverageFuelIncome, StringFormat='Average Fuel Income: {0:F2}$'}" Margin="0,0,0,10"/>

                        <TextBlock Text="Top 3 Popular Pumps:" FontWeight="Bold" Margin="0,10,0,5"/>
                        <ListBox ItemsSource="{Binding MostPopularPumps}" BorderThickness="0" Background="Transparent"/>
                    </StackPanel>
                </TabItem>
                <TabItem Header="Goods &amp; Orders">
                    <StackPanel Margin="10">
                        <TextBlock Text="Overall Income Stats:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding TotalIncome, StringFormat='Total Income (All): {0:F2}$'}" />
                        <TextBlock Text="{Binding AverageIncome, StringFormat='Average Order Value: {0:F2}$'}" Margin="0,0,0,10"/>

                        <TextBlock Text="Top 3 Popular Goods:" FontWeight="Bold" Margin="0,10,0,5"/>
                        <ListBox ItemsSource="{Binding MostPopularProducts}" BorderThickness="0" Background="Transparent"/>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Grid>



        <!--Users Grid-->

        <Grid x:Name="UsersGrid" 
                Grid.Row="1" 
                Grid.Column="1"
                Visibility="Hidden">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Label Grid.Row="0" FontWeight="Bold" Content="USERS"/>

            <DataGrid Grid.Row="1" 
                      AutoGenerateColumns="False" 
                      ItemsSource="{Binding Users}"
                      SelectedItem="{Binding SelectedUser, Mode=TwoWay}" 
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      Background="White"
                      BorderBrush="#DDD">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="2*"/>
                    <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="1*"/>
                    <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="1*"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Grid.Row="2"
                    Margin="0,10,0,0">
                <StackPanel.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Margin" Value="5,0,0,0"/>
                        <Setter Property="Height" Value="30"/>
                        <Setter Property="Width" Value="80"/>
                        <Setter Property="Background" Value="#DCDCDC"/>
                    </Style>
                </StackPanel.Resources>

                <Button Content="Add" Command="{Binding AddUserCommand}"/>
                <Button Content="Edit" Command="{Binding EditUserCommand}"/>
                <Button Content="Delete" Command="{Binding DeleteUserCommand}" Foreground="Red"/>
            </StackPanel>
        </Grid>


        <Grid x:Name="ReportsGrid" Grid.Row="1" Grid.Column="1" Visibility="Hidden">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0" FontWeight="Bold">FINANCIAL REPORTS (Z-REPORTING)</Label>

            <Border Grid.Row="1" Background="#FEFEFE" Padding="20" CornerRadius="5">
                <StackPanel MaxWidth="400" HorizontalAlignment="Left">
                    <TextBlock Text="Select a period to generate the final report for revenue and bonuses." 
                       TextWrapping="Wrap" Margin="0,0,0,20" Foreground="#666"/>

                    <Label Content="Start Date:"/>
                    <DatePicker SelectedDate="{Binding ReportStartDate}" Margin="0,0,0,15" Height="30"/>

                    <Label Content="End Date:"/>
                    <DatePicker SelectedDate="{Binding ReportEndDate}" Margin="0,0,0,25" Height="30"/>

                    <Button Content="Generate and Export..." 
                    Command="{Binding GenerateFinancialReportCommand}"
                    Height="40" Background="#DCDCDC" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>

        <!--Stock Grid-->

        <Grid x:Name="StocksGrid" Grid.Row="1" Grid.Column="1" Visibility="Hidden">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0" FontWeight="Bold">STOCK</Label>

            <TabControl Grid.Row="1" Background="#FEFEFE">
                <TabItem Header="Goods">
                    <Grid>
                        <DataGrid Margin="0,0,0,35" ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedGood}" 
                                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  SelectionMode="Single" SelectionUnit="FullRow" Background="White" BorderBrush="#DDD">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="50"/>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                                <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat='{}{0:F2}$'}" Width="1*"/>
                                <DataGridTextColumn Header="BarCode" Binding="{Binding BarCode}" Width="1*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,5">
                            <Button Content="Add" Command="{Binding AddGoodCommand}" Width="80" Height="30" Margin="5,0,0,0" Background="#DCDCDC"/>
                            <Button Content="Edit" Command="{Binding EditGoodCommand}" Width="80" Height="30" Margin="5,0,0,0" Background="#DCDCDC"/>
                            <Button Content="Delete" Command="{Binding DeleteGoodCommand}" Foreground="Red" Width="80" Height="30" Margin="5,0,0,0" Background="#DCDCDC"/>
                        </StackPanel>
                    </Grid>
                </TabItem>
                <TabItem Header="Fuel Types">
                    <Grid>
                        <Grid>
                            <DataGrid Margin="0,0,0,35" ItemsSource="{Binding FuelTypes}" 
              SelectedItem="{Binding SelectedFuelType, Mode=TwoWay}"
              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" 
              SelectionMode="Single" SelectionUnit="FullRow" 
              Background="White" BorderBrush="#DDD">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="50"/>
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                                    <DataGridTextColumn Header="Price per L" Binding="{Binding Price, StringFormat='{}{0:F2}$'}" Width="1*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,5">
                                <Button Content="Add" Command="{Binding AddFuelTypeCommand}" Width="80" Height="30" Margin="5,0,0,0" Background="#DCDCDC"/>
                                <Button Content="Edit" Command="{Binding EditFuelTypeCommand}" Width="80" Height="30" Margin="5,0,0,0" Background="#DCDCDC"/>
                                <Button Content="Delete" Command="{Binding DeleteFuelTypeCommand}" Foreground="Red" Width="80" Height="30" Margin="5,0,0,0" Background="#DCDCDC"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>




        <!--Equipment Grid-->

        <Grid x:Name="EquipmentGrid" Grid.Row="1" Grid.Column="1" Visibility="Hidden">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0" FontWeight="Bold">EQUIPMENT</Label>

            <TabControl Grid.Row="1" Background="#FEFEFE">
                <TabItem Header="Pumps">
                    <Grid>
                        <DataGrid Margin="0,0,0,35" ItemsSource="{Binding Pumps}" 
                                    SelectedItem="{Binding SelectedPump, Mode=TwoWay}"
                                    AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" 
                                    SelectionMode="Single" SelectionUnit="FullRow" 
                                    Background="White" BorderBrush="#DDD">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="50"/>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,5">
                            <Button Content="Add" Command="{Binding AddPumpCommand}" Width="80" Height="30" Margin="5,0,0,0" Background="#DCDCDC"/>
                            <Button Content="Edit" Command="{Binding EditPumpCommand}" Width="80" Height="30" Margin="5,0,0,0" Background="#DCDCDC"/>
                            <Button Content="Delete" Command="{Binding DeletePumpCommand}" Foreground="Red" Width="80" Height="30" Margin="5,0,0,0" Background="#DCDCDC"/>
                        </StackPanel>
                    </Grid>
                </TabItem>
                <TabItem Header="Tanks">
                    <Grid>
                        <DataGrid Margin="0,0,0,35" ItemsSource="{Binding Tanks}" 
                                        SelectedItem="{Binding SelectedTank, Mode=TwoWay}"
                                        AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" 
                                        SelectionMode="Single" SelectionUnit="FullRow" 
                                        Background="White" BorderBrush="#DDD">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="50"/>
                                <DataGridTextColumn Header="Fuel Type" Binding="{Binding FuelType.Name}" Width="1.5*"/>
                                <DataGridTextColumn Header="Volume (L)" Binding="{Binding Volume, StringFormat='{}{0:F2}'}" Width="1*"/>
                                <DataGridTextColumn Header="Capacity (L)" Binding="{Binding Capacity, StringFormat='{}{0:F2}'}" Width="1*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,5">
                            <Button Content="Add" Command="{Binding AddTankCommand}" Width="80" Height="30" Margin="5,0,0,0" Background="#DCDCDC"/>
                            <Button Content="Edit" Command="{Binding EditTankCommand}" Width="80" Height="30" Margin="5,0,0,0" Background="#DCDCDC"/>
                            <Button Content="Delete" Command="{Binding DeleteTankCommand}" Foreground="Red" Width="80" Height="30" Margin="5,0,0,0" Background="#DCDCDC"/>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>



        <!--Settings Grid-->
        
        <Grid x:Name="SettingsGrid"
              Grid.Row="1"
              Grid.Column="1"
              Visibility="Hidden">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0"
                   FontWeight="Bold">
                SETTINGS
            </Label>
            <Border Grid.Row="1"
                    Background="#FEFEFE"
                    Padding="10"
                    CornerRadius="5">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Bonus rate: "/>
                        <TextBox x:Name="BonusRateTextBox"
                                 PreviewKeyDown="BonusRateTextBox_PreviewKeyDown"
                                 TextChanged="BonusRateTextBox_TextChanged" Text="{Binding SettingsCopy.BonusRate}" Width="100"></TextBox>
                        <Label Content="%"/>
                        <Label x:Name="ErrorLabel" FontWeight="ExtraBold" Content=""/>
                     </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <Label Content="Database filename: "/>
                        <TextBox x:Name="DatabaseFilenameTextBox" TextChanged="DatabaseFilenameTextBox_TextChanged" Text="{Binding DatabaseName}" Width="100"></TextBox>
                        <Label x:Name="DBErrorLabel" FontWeight="ExtraBold" Content=""/>
                    </StackPanel>
                </StackPanel>
                
            </Border>
            <Button x:Name="SaveSettingsButton"
                Content="Save" 
                    Grid.Row="1"
                     HorizontalAlignment="Right" 
                    VerticalAlignment="Bottom"
                    Margin="10"
                    Width="80"
                    Height="30"
                    IsEnabled="{Binding IsSaveButtonEnabled}"
                    Command="{Binding SaveSettingsCommand}"
                    Background="#DCDCDC"/>
        </Grid>

    </Grid>
</Window>
