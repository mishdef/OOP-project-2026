<Window x:Class="Gsstwpfmock.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Gsstwpfmock"
        mc:Ignorable="d"
        Title="Terminal Login" SizeToContent="WidthAndHeight" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" 
         Height="391" Width="552" Icon="/Accets/logo.jpg">

    <Grid Margin="20">

        <StackPanel Width="400">
            <Image Source="/Accets/logotip-petrorazmik_en-removebg-preview (2).png" 
                       Width="398" Margin="0,0,0,25" Stretch="Uniform" Height="80"/>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Login:" 
                               VerticalAlignment="Center" Foreground="#555" FontWeight="SemiBold"/>
                <TextBox x:Name="LoginBox" Grid.Row="0" Grid.Column="1" 
                             Height="30" Padding="5,0" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Password:" 
                               VerticalAlignment="Center" Foreground="#555" FontWeight="SemiBold"/>
                <PasswordBox x:Name="PasswordBox" Grid.Row="1" Grid.Column="1" 
                                 Height="30" Padding="5,0" VerticalContentAlignment="Center"/>
            </Grid>

            <Button Content="Sign in" Click="Button_Click" 
                        Height="35" FontWeight="Bold" 
                        BorderThickness="0" Cursor="Hand">
            </Button>
        </StackPanel>
    </Grid>
</Window>