<Window x:Class="PetrolWPF.View.BonusCardsManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bonus Cards Management" Height="450" Width="600"
        WindowStartupLocation="CenterOwner" Background="#F4F4F4" Icon="/Accets/logo.jpg">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" FontWeight="Bold" Content="BONUS CARDS"/>

        <DataGrid Grid.Row="1" AutoGenerateColumns="False" ItemsSource="{Binding BonusCards}"
                  SelectedItem="{Binding SelectedCard, Mode=TwoWay}" CanUserAddRows="False"
                  IsReadOnly="True" SelectionMode="Single" SelectionUnit="FullRow"
                  Background="White" BorderBrush="#DDD" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Client Name" Binding="{Binding ClientName}" Width="2*"/>
                <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}" Width="1.5*"/>
                <DataGridTextColumn Header="Balance" Binding="{Binding BonusBalance, StringFormat='{}{0:F2}'}" Width="1*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <StackPanel.Resources>
                <Style TargetType="Button">
                    <Setter Property="Margin" Value="5,0,0,0"/>
                    <Setter Property="Height" Value="30"/>
                    <Setter Property="Width" Value="80"/>
                    <Setter Property="Background" Value="#DCDCDC"/>
                </Style>
            </StackPanel.Resources>
            <Button Content="Add" Command="{Binding AddCardCommand}"/>
            <Button Content="Edit" Command="{Binding EditCardCommand}"/>
            <Button Content="Delete" Command="{Binding DeleteCardCommand}" Foreground="Red"/>
        </StackPanel>
    </Grid>
</Window>