<Window x:Class="PetrolWPF.View.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Product" Height="450" Width="350"
        WindowStartupLocation="CenterScreen" Background="#F4F4F4"
        ResizeMode="NoResize" Icon="/Accets/logo.jpg">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Content="Product Name:"/>
        <TextBox x:Name="NameTextBox" Grid.Row="1" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

        <Label Grid.Row="2" Content="Price ($):"/>
        <TextBox x:Name="PriceTextBox" Grid.Row="3" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

        <Label Grid.Row="4" Content="Barcode:"/>
        <TextBox x:Name="BarcodeTextBox" Grid.Row="5" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

        <Label Grid.Row="6" Content="Image:"/>
        <Grid Grid.Row="7" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Height="100" Background="White" Margin="0,0,10,0">
                <Image x:Name="ProductImagePreview" Stretch="Uniform" Margin="5"/>
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                <Button Width="80" Height="35" Margin="0,0,0,5" Click="BrowseButton_Click" Background="#EAEAEA">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Accets/upload.png" Width="16" Height="16" Margin="5,0,0,0"/>
                        <Label>Upload</Label>
                    </StackPanel>
                </Button>
                <Button Width="80" Height="35" Click="DeleteImageButton_Click" Background="#FFCCCC" Foreground="Black">
                    <StackPanel Orientation="Horizontal">
                        <Label>Delete</Label>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="Save" Width="80" Height="35"  FontWeight="Bold" Margin="0,0,10,0" Click="SaveButton_Click"/>
            <Button Content="Cancel" Width="80" Height="35"  Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>