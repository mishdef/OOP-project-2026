<Window x:Class="PetrolWPF.View.TankEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Tank" Height="344" Width="300"
        WindowStartupLocation="CenterScreen" Background="#F4F4F4"
        ResizeMode="NoResize" Icon="/Accets/logo.jpg">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Content="Fuel Type:" />
        <ComboBox x:Name="FuelTypeComboBox" Grid.Row="1" Height="30" DisplayMemberPath="Name" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

        <Label Grid.Row="2" Content="Capacity (L):" />
        <TextBox x:Name="CapacityTextBox" Grid.Row="3" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

        <Label Grid.Row="4" Content="Current Volume (L):" />
        <TextBox x:Name="VolumeTextBox" Grid.Row="5" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="Save" Width="80" Height="35" FontWeight="Bold" Margin="0,0,10,0" Click="SaveButton_Click"/>
            <Button Content="Cancel" Width="80" Height="35"  Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>