<Window x:Class="PetrolWPF.View.BonusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PetrolWPF.View"
        mc:Ignorable="d"
        Title="Bonus Card Details" Width="400" SizeToContent="Height" 
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner" Background="#F5F5F5" Icon="/Accets/logo.jpg">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <GroupBox Header="Card Information" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Card number:" Margin="0,0,15,8" Foreground="Gray" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="CardNumberTextBlock" Text="{Binding BonusCard.Barcode}" FontWeight="Bold" Margin="0,0,0,8" VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Bonus balance:" Margin="0,0,15,8" Foreground="Gray" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="BonusAmountTextBlock" Text="{Binding BonusCard.BonusBalance, StringFormat='{}{0:F2}'}" FontWeight="Bold" Foreground="#2E7D32" Margin="0,0,0,8" VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Client:" Margin="0,0,15,0" Foreground="Gray" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="ClientTextBlock" Text="{Binding BonusCard.ClientName}" FontWeight="Bold" VerticalAlignment="Center"/>
                </Grid>
            </GroupBox>

            <GroupBox Header="Discount Management" Padding="10" Margin="0,10,0,0">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Bonus used in receipt:" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" x:Name="BonusUsedInReceiptTextBlock" Text="{Binding Discount, StringFormat='{}{0:F2}'}" FontWeight="Bold" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Set discount:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Grid.Column="1" x:Name="AddToReceiptTextBox" Height="26" VerticalContentAlignment="Center" Padding="5,0"/>
                        <Button Grid.Column="2" x:Name="AddToReceiptButton" Click="AddToReceiptButton_Click" Content="Apply" Width="70" Height="26" Margin="10,0,0,0"  BorderThickness="0"/>
                    </Grid>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Remove bonuses from receipt" Click="RemoveBonusesButton_Click" Height="30" Margin="0,0,10,0"  BorderThickness="0"/>
            <Button Grid.Column="1" Content="Close" Click="CloseButton_Click" Height="30" Width="80"/>
        </Grid>
    </Grid>
</Window>