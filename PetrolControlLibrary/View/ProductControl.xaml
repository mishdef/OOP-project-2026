<UserControl x:Class="PetrolControlLibrary.ProductControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PetrolControlLibrary"
             xmlns:conv="clr-namespace:PetrolControlLibrary.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="141.236" d:DesignWidth="140.225">
    <UserControl.Resources>
        <conv:ByteArrayToImageConverter x:Key="ImageConverter"/>
    </UserControl.Resources>

    <Border Background="White"
            CornerRadius="10"
            BorderBrush="Gray"
            BorderThickness="2">
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Image Grid.Row="0"
                   Source="{Binding Image, Converter={StaticResource ImageConverter}}"
                   Stretch="Uniform"
                   Margin="0,5"/>

            <Border Grid.Row="0" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top" 
                    Width="14" Height="14" 
                    Background="#F4F4F4" 
                    CornerRadius="9" 
                    BorderBrush="#CCCCCC" 
                    BorderThickness="1"
                    ToolTip="{Binding Name}"
                    Cursor="Help">
                <TextBlock Text="i" 
                           FontWeight="Bold" 
                           Foreground="#888888" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center" 
                           FontSize="11"
                           Margin="0,0,0,1"/>
            </Border>

            <StackPanel Grid.Row="1">
                <TextBlock FontWeight="Bold" 
                           Text="{Binding Name}" 
                           TextTrimming="CharacterEllipsis" 
                           Margin="5,0,5,0"/>
                <Grid>
                    <Label FontStyle="Italic">Price:</Label>
                    <TextBlock FontStyle="Italic" HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding Price, StringFormat=' {0:F2}$'}"/>
                </Grid>
            </StackPanel>

        </Grid>
    </Border>
</UserControl>