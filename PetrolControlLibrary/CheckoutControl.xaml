<UserControl x:Class="PetrolControlLibrary.CheckoutControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PetrolControlLibrary"
             mc:Ignorable="d" d:DesignHeight="500" d:DesignWidth="300">
    <Border Grid.Column="0" 
        Background="White" CornerRadius="5" BorderBrush="#DDD" BorderThickness="1" Grid.Row="1">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Label Content="ORDER" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

            <Border Margin="0,0" Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Padding="10"/>
            <ItemsControl ItemsSource="{Binding CartItems}" Grid.Row="1" Margin="0,10,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <local:OrderItemControl></local:OrderItemControl>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

                <StackPanel Grid.Row="2" Margin="0,10">
                <Separator Background="#DDD" Margin="0,5"/>
                <TextBlock Text="{Binding Discount, StringFormat='Discount: {0:F2}$'}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Discount}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding Subtotal, StringFormat='Total: {0:F2}$'}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right"/>
            </StackPanel>

            <Button Grid.Row="3" 
                Content="Checkout" 
                Height="45" 
                FontWeight="Bold"
                BorderBrush="#00000000"
                Background="#DDFDDD"
                Command="{Binding CheckoutCommand}"/>
        </Grid>
    </Border>
</UserControl>
